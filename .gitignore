# =========================

# AURA .gitignore

# =========================

# -------------------------

# Python

# -------------------------

**pycache**/
*.pyc
*.pyo
*.pyd
*.so

# -------------------------

# Virtual Environments

# -------------------------

venv/
.venv/
env/

# -------------------------

# Environment Variables

# -------------------------

.env
.env.*

# -------------------------

# Temp / Debug / Logs

# -------------------------

tmp_*
tmp*/
temp*/
logs/
*.log
dev_log.txt

# -------------------------

# Memory (Private Data)

# -------------------------

memory/*.json
memory/*.db
memory/*.sqlite3
memory/vector_store/

# -------------------------

# Security (Sensitive)

# -------------------------

security/*.json
security/*.hash
security/.secret.key

# -------------------------

# Screenshots / Artifacts

# -------------------------

screenshot_*.png

# -------------------------

# OS Files

# -------------------------

.DS_Store
Thumbs.db

# -------------------------

# Editor / IDE

# -------------------------

.vscode/
.idea/

# -------------------------

# Build / Cache

# -------------------------

dist/
build/

# -------------------------

# Misc

# -------------------------

*.tmp
*.bak
# Generated files
generated/
*.pdf
*.docx
*.pptx
*.txt

# AURA outputs
AI-*